SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here
VITE_SUPABASE_PROJECT_ID=your_project_ref_here

# --- Netopia Payments (Edge Function secrets) ---
# API Key string from Netopia admin panel (Profil → Securitate → API Key).
# Typically 50-300 characters. NU pune aici certificatul PEM (-----BEGIN CERTIFICATE-----).
NETOPIA_API_KEY=your_netopia_api_key
# POS Signature, format XXXX-XXXX-XXXX-XXXX-XXXX
NETOPIA_POS_SIGNATURE=XXXX-XXXX-XXXX-XXXX-XXXX
# "sandbox" sau "live"
NETOPIA_ENV=sandbox
# Public Key PEM (BEGIN CERTIFICATE sau BEGIN PUBLIC KEY) — folosit doar pentru verificarea IPN
NETOPIA_PUBLIC_KEY="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# URL public folosit pentru returnUrl/cancelUrl
PUBLIC_SITE_URL=https://mamalucica.ro

ALLOWED_ORIGINS=https://yourdomain.ro,https://www.yourdomain.ro
